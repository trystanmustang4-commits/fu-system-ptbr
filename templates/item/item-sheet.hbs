{{!-- Item Sheet --}}
<div class="fabula-ultima fu-item-sheet fu-theme-{{theme}}">
  <header class="fu-sheet-header">
    <img class="fu-item-img fu-clickable-img" src="{{item.img}}" alt="{{item.name}}">
    <div class="fu-header-fields">
      <input class="fu-name-input" type="text" name="name"
             value="{{item.name}}" placeholder="Nome do item">
      <div class="fu-muted" style="font-size:11px;text-transform:uppercase">
        {{fu_localize (concat "TYPES.Item." item.type)}}
        {{#if system.source}} · {{system.source}}{{/if}}
      </div>
    </div>
  </header>

  <div class="fu-item-body fu-scroll">

    {{!-- Description --}}
    <section class="fu-section">
      <div class="fu-section-header"><h3>Descrição</h3></div>
      <textarea name="system.description" rows="5"
                style="width:100%;resize:vertical;font-family:inherit"
                placeholder="Descrição do item...">{{system.description}}</textarea>
    </section>

    {{!-- Weapon fields --}}
    {{#if isWeapon}}
    <section class="fu-section">
      <div class="fu-section-header"><h3>Arma</h3></div>
      <div class="fu-form-grid" style="display:grid;grid-template-columns:1fr 1fr;gap:8px">
        <div class="form-group">
          <label>Custo</label>
          <input type="number" name="system.cost" value="{{system.cost}}">
        </div>
        <div class="form-group">
          <label>Mãos</label>
          <select name="system.hands">
            <option value="1" {{#if (fu_is system.hands 1)}}selected{{/if}}>1 mão</option>
            <option value="2" {{#if (fu_is system.hands 2)}}selected{{/if}}>2 mãos</option>
          </select>
        </div>
        <div class="form-group">
          <label>Alcance</label>
          <select name="system.range">
            <option value="melee"  {{#if (fu_is system.range "melee")}}selected{{/if}}>Corpo a corpo</option>
            <option value="ranged" {{#if (fu_is system.range "ranged")}}selected{{/if}}>À distância</option>
          </select>
        </div>
        <div class="form-group">
          <label>Marcial</label>
          <input type="checkbox" name="system.martial" {{#if system.martial}}checked{{/if}}>
        </div>
        <div class="form-group">
          <label>Precisão Attr 1</label>
          <select name="system.precision.0">
            {{#each config.ATTRIBUTES}}
            <option value="{{@key}}" {{#if (fu_is (lookup ../../system.precision 0) @key)}}selected{{/if}}>
              {{@key}} – {{fu_localize this}}
            </option>
            {{/each}}
          </select>
        </div>
        <div class="form-group">
          <label>Precisão Attr 2</label>
          <select name="system.precision.1">
            {{#each config.ATTRIBUTES}}
            <option value="{{@key}}" {{#if (fu_is (lookup ../../system.precision 1) @key)}}selected{{/if}}>
              {{@key}} – {{fu_localize this}}
            </option>
            {{/each}}
          </select>
        </div>
        <div class="form-group">
          <label>Bônus de Precisão</label>
          <input type="number" name="system.precisionBonus" value="{{system.precisionBonus}}">
        </div>
        <div class="form-group">
          <label>Dano</label>
          <input type="number" name="system.damage" value="{{system.damage}}">
        </div>
        <div class="form-group">
          <label>Tipo de Dano</label>
          <select name="system.damageType">
            {{#each config.DAMAGE_TYPES}}
            <option value="{{@key}}" {{#if (fu_is ../../system.damageType @key)}}selected{{/if}}>
              {{fu_localize this}}
            </option>
            {{/each}}
          </select>
        </div>
        <div class="form-group">
          <label>Qualidade</label>
          <input type="text" name="system.quality" value="{{system.quality}}" placeholder="Efeito especial...">
        </div>
      </div>
    </section>
    {{/if}}

    {{!-- Armor fields --}}
    {{#if isArmor}}
    <section class="fu-section">
      <div class="fu-section-header"><h3>Armadura</h3></div>
      <div class="fu-form-grid" style="display:grid;grid-template-columns:1fr 1fr;gap:8px">
        <div class="form-group"><label>Custo</label>
          <input type="number" name="system.cost" value="{{system.cost}}"></div>
        <div class="form-group"><label>Marcial</label>
          <input type="checkbox" name="system.martial" {{#if system.martial}}checked{{/if}}></div>
        <div class="form-group"><label>DEF Fixo</label>
          <input type="number" name="system.defFixed" value="{{system.defFixed}}" placeholder="Deixe vazio para usar atributo"></div>
        <div class="form-group"><label>Attr DEF</label>
          <select name="system.defFormula">
            {{#each config.ATTRIBUTES}}
            <option value="{{@key}}" {{#if (fu_is ../../system.defFormula @key)}}selected{{/if}}>{{@key}}</option>
            {{/each}}
          </select>
        </div>
        <div class="form-group"><label>Bônus DEF</label>
          <input type="number" name="system.defBonus" value="{{system.defBonus}}"></div>
        <div class="form-group"><label>Bônus DEF.M</label>
          <input type="number" name="system.mdefBonus" value="{{system.mdefBonus}}"></div>
        <div class="form-group"><label>Mod. Iniciativa</label>
          <input type="number" name="system.initiativeModifier" value="{{system.initiativeModifier}}"></div>
        <div class="form-group"><label>Qualidade</label>
          <input type="text" name="system.quality" value="{{system.quality}}" placeholder="Efeito especial..."></div>
      </div>
    </section>
    {{/if}}

    {{!-- Shield fields --}}
    {{#if isShield}}
    <section class="fu-section">
      <div class="fu-section-header"><h3>Escudo</h3></div>
      <div class="fu-form-grid" style="display:grid;grid-template-columns:1fr 1fr;gap:8px">
        <div class="form-group"><label>Custo</label>
          <input type="number" name="system.cost" value="{{system.cost}}"></div>
        <div class="form-group"><label>Marcial</label>
          <input type="checkbox" name="system.martial" {{#if system.martial}}checked{{/if}}></div>
        <div class="form-group"><label>Bônus DEF</label>
          <input type="number" name="system.defBonus" value="{{system.defBonus}}"></div>
        <div class="form-group"><label>Bônus DEF.M</label>
          <input type="number" name="system.mdefBonus" value="{{system.mdefBonus}}"></div>
        <div class="form-group"><label>Mod. Iniciativa</label>
          <input type="number" name="system.initiativeModifier" value="{{system.initiativeModifier}}"></div>
        <div class="form-group"><label>Qualidade</label>
          <input type="text" name="system.quality" value="{{system.quality}}" placeholder="Efeito especial..."></div>
      </div>
    </section>
    {{/if}}

    {{!-- Class fields --}}
    {{#if isClass}}
    <section class="fu-section">
      <div class="fu-section-header"><h3>Classe</h3></div>
      <div class="fu-form-grid" style="display:grid;grid-template-columns:1fr 1fr;gap:8px">
        <div class="form-group"><label>Fonte</label>
          <input type="text" name="system.source" value="{{system.source}}" placeholder="Livro Básico..."></div>
        <div class="form-group"><label>Nível</label>
          <input type="number" name="system.level" value="{{system.level}}" min="1" max="10"></div>
        <div class="form-group"><label>Bônus PV</label>
          <input type="number" name="system.benefits.pv" value="{{system.benefits.pv}}"></div>
        <div class="form-group"><label>Bônus PM</label>
          <input type="number" name="system.benefits.pm" value="{{system.benefits.pm}}"></div>
        <div class="form-group"><label>Bônus PI</label>
          <input type="number" name="system.benefits.pi" value="{{system.benefits.pi}}"></div>
      </div>
    </section>
    {{/if}}

    {{!-- Power fields --}}
    {{#if isPower}}
    <section class="fu-section">
      <div class="fu-section-header"><h3>Poder</h3></div>
      <div class="fu-form-grid" style="display:grid;grid-template-columns:1fr 1fr;gap:8px">
        <div class="form-group"><label>Fonte / Classe</label>
          <input type="text" name="system.source" value="{{system.source}}" placeholder="Nome da classe..."></div>
        <div class="form-group"><label>Nível Máximo</label>
          <input type="number" name="system.maxLevel" value="{{system.maxLevel}}" min="1" max="10"></div>
        <div class="form-group"><label>Nível Atual</label>
          <input type="number" name="system.level" value="{{system.level}}" min="1" max="10"></div>
      </div>
    </section>
    {{/if}}

    {{!-- Spell fields --}}
    {{#if isSpell}}
    <section class="fu-section">
      <div class="fu-section-header"><h3>Feitiço</h3></div>
      <div class="fu-form-grid" style="display:grid;grid-template-columns:1fr 1fr;gap:8px">
        <div class="form-group"><label>Disciplina</label>
          <input type="text" name="system.discipline" value="{{system.discipline}}"></div>
        <div class="form-group"><label>Custo (PM)</label>
          <input type="number" name="system.mpCost" value="{{system.mpCost}}"></div>
        <div class="form-group"><label>Alvo</label>
          <select name="system.target">
            <option value="single" {{#if (fu_is system.target "single")}}selected{{/if}}>Único</option>
            <option value="multi"  {{#if (fu_is system.target "multi")}}selected{{/if}}>Múltiplos</option>
            <option value="all"    {{#if (fu_is system.target "all")}}selected{{/if}}>Todos</option>
            <option value="self"   {{#if (fu_is system.target "self")}}selected{{/if}}>Si mesmo</option>
            <option value="area"   {{#if (fu_is system.target "area")}}selected{{/if}}>Área</option>
          </select>
        </div>
        <div class="form-group"><label>Duração</label>
          <select name="system.duration">
            <option value="instant"   {{#if (fu_is system.duration "instant")}}selected{{/if}}>Instantâneo</option>
            <option value="scene"     {{#if (fu_is system.duration "scene")}}selected{{/if}}>Cena</option>
            <option value="sustained" {{#if (fu_is system.duration "sustained")}}selected{{/if}}>Sustentado</option>
          </select>
        </div>
        <div class="form-group"><label>Ofensivo</label>
          <input type="checkbox" name="system.isOffensive" {{#if system.isOffensive}}checked{{/if}}></div>
        <div class="form-group"><label>Ritual</label>
          <input type="checkbox" name="system.isRitual" {{#if system.isRitual}}checked{{/if}}></div>
        {{#if system.isOffensive}}
        <div class="form-group"><label>Precisão Attr 1</label>
          <select name="system.precision.0">
            {{#each config.ATTRIBUTES}}
            <option value="{{@key}}" {{#if (fu_is (lookup ../../system.precision 0) @key)}}selected{{/if}}>{{@key}}</option>
            {{/each}}
          </select>
        </div>
        <div class="form-group"><label>Precisão Attr 2</label>
          <select name="system.precision.1">
            {{#each config.ATTRIBUTES}}
            <option value="{{@key}}" {{#if (fu_is (lookup ../../system.precision 1) @key)}}selected{{/if}}>{{@key}}</option>
            {{/each}}
          </select>
        </div>
        <div class="form-group"><label>Dano</label>
          <input type="number" name="system.damage" value="{{system.damage}}"></div>
        <div class="form-group"><label>Tipo de Dano</label>
          <select name="system.damageType">
            {{#each config.DAMAGE_TYPES}}
            <option value="{{@key}}" {{#if (fu_is ../../system.damageType @key)}}selected{{/if}}>{{fu_localize this}}</option>
            {{/each}}
          </select>
        </div>
        {{/if}}
      </div>
    </section>
    {{/if}}

    {{!-- Consumable fields --}}
    {{#if isConsumable}}
    <section class="fu-section">
      <div class="fu-section-header"><h3>Consumível</h3></div>
      <div class="fu-form-grid" style="display:grid;grid-template-columns:1fr 1fr;gap:8px">
        <div class="form-group"><label>Custo</label>
          <input type="number" name="system.cost" value="{{system.cost}}"></div>
        <div class="form-group"><label>Quantidade</label>
          <input type="number" name="system.quantity" value="{{system.quantity}}" min="0"></div>
        <div class="form-group" style="grid-column:1/-1"><label>Efeito</label>
          <textarea name="system.effect" rows="3" style="width:100%;resize:vertical;font-family:inherit"
                    placeholder="Efeito ao usar...">{{system.effect}}</textarea></div>
      </div>
    </section>
    {{/if}}

  </div>
</div>
