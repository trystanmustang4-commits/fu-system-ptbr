{{!-- Character Sheet: Header (full-width top bar) --}}
<header class="fu-sheet-header {{#if isCrisis}}fu-in-crisis{{/if}}">

  {{!-- Name --}}
  <div class="fu-header-name">
    {{#if locked}}
      <h2 class="fu-name-display">{{actor.name}}</h2>
    {{else}}
      <input class="fu-name-input" type="text" name="name"
             value="{{actor.name}}" placeholder="Nome do Personagem" data-lockable="1">
    {{/if}}
  </div>

  {{!-- Identity + Pronouns --}}
  <div class="fu-header-identity">
    {{#if locked}}
      <span class="fu-identity-display fu-muted">
        {{system.identity}}{{#if system.pronouns}} · {{system.pronouns}}{{/if}}
      </span>
    {{else}}
      <input class="fu-field" type="text" name="system.identity"
             value="{{system.identity}}" placeholder="Identidade" data-lockable="1">
      <input class="fu-field fu-pronouns" type="text" name="system.pronouns"
             value="{{system.pronouns}}" placeholder="Pronomes" data-lockable="1">
    {{/if}}
  </div>

  {{!-- Game-state numbers (always editable) --}}
  <div class="fu-header-numbers">
    <label class="fu-num-label">
      <span>Nv</span>
      <input type="number" name="system.level" value="{{system.level}}" min="1" max="50">
    </label>
    <label class="fu-num-label">
      <span>Fábula</span>
      <input type="number" name="system.fabula" value="{{system.fabula}}" min="0">
    </label>
    <label class="fu-num-label">
      <span>Zênites</span>
      <input type="number" name="system.zeni" value="{{system.zeni}}" min="0" style="width:64px">
    </label>
  </div>

  {{!-- Controls: lock + view mode --}}
  <div class="fu-header-controls">
    <button class="fu-control-btn {{#unless locked}}fu-unlocked{{/unless}}" type="button"
            data-action="toggleLock"
            title="{{#if locked}}Desbloquear ficha para edição{{else}}Bloquear ficha{{/if}}">
      <i class="fas {{#if locked}}fa-lock{{else}}fa-lock-open{{/if}}"></i>
    </button>
    <button class="fu-control-btn {{#if isScrollView}}fu-active-view{{/if}}" type="button"
            data-action="toggleView"
            title="{{#if isScrollView}}Alternar para modo de abas{{else}}Alternar para modo de página completa{{/if}}">
      <i class="fas {{#if isScrollView}}fa-list{{else}}fa-table-columns{{/if}}"></i>
    </button>
  </div>

</header>
