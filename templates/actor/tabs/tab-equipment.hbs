{{!-- Tab: Equipment --}}
<div class="fu-tab-body fu-scroll" data-tab="equipment" data-group="primary">

  {{!-- Weapons --}}
  <div class="fu-section-header">
    <h3>Armas</h3>
    <button class="fu-btn" type="button" data-action="createItem" data-type="weapon">
      <i class="fas fa-plus"></i>
    </button>
  </div>

  <div class="fu-item-list">
  {{#each weapons}}
    <div class="fu-item-row" data-item-id="{{this.id}}">
      <a class="equipped-toggle {{#if this.system.equipped}}equipped{{/if}}"
         data-action="toggleEquip" title="{{#if this.system.equipped}}Desequipar{{else}}Equipar{{/if}}">
        <i class="fas {{#if this.system.equipped}}fa-shield-alt{{else}}fa-circle{{/if}}"></i>
      </a>
      <img class="item-img" src="{{this.img}}" alt="{{this.name}}">
      <span class="item-name" data-action="editItem">{{this.name}}</span>
      <span class="fu-muted" style="font-size:11px">
        {{this.system.precision.[0]}}/{{this.system.precision.[1]}}
        {{#if this.system.precisionBonus}}+{{this.system.precisionBonus}}{{/if}}
        · {{this.system.damage}} {{this.system.damageType}}
      </span>
      <div class="item-controls">
        <a data-action="rollWeapon" title="Rolar Precisão"><i class="fas fa-dice-d20"></i></a>
        <a data-action="editItem"   title="Editar"><i class="fas fa-edit"></i></a>
        <a data-action="deleteItem" title="Excluir" class="fu-btn-danger"><i class="fas fa-trash"></i></a>
      </div>
    </div>
  {{else}}
    <p class="fu-muted fu-empty-notice">Nenhuma arma.</p>
  {{/each}}
  </div>

  {{!-- Armor --}}
  <div class="fu-section-header" style="margin-top:14px">
    <h3>Armaduras</h3>
    <button class="fu-btn" type="button" data-action="createItem" data-type="armor">
      <i class="fas fa-plus"></i>
    </button>
  </div>

  <div class="fu-item-list">
  {{#each armors}}
    <div class="fu-item-row" data-item-id="{{this.id}}">
      <a class="equipped-toggle {{#if this.system.equipped}}equipped{{/if}}"
         data-action="toggleEquip">
        <i class="fas {{#if this.system.equipped}}fa-shield-alt{{else}}fa-circle{{/if}}"></i>
      </a>
      <img class="item-img" src="{{this.img}}" alt="{{this.name}}">
      <span class="item-name" data-action="editItem">{{this.name}}</span>
      <span class="fu-muted" style="font-size:11px">
        DEF {{this.system.defBonus}} · DEF.M {{this.system.mdefBonus}}
        · Init {{fu_format_sign this.system.initiativeModifier}}
      </span>
      <div class="item-controls">
        <a data-action="editItem"   title="Editar"><i class="fas fa-edit"></i></a>
        <a data-action="deleteItem" title="Excluir" class="fu-btn-danger"><i class="fas fa-trash"></i></a>
      </div>
    </div>
  {{else}}
    <p class="fu-muted fu-empty-notice">Nenhuma armadura.</p>
  {{/each}}
  </div>

  {{!-- Shields --}}
  <div class="fu-section-header" style="margin-top:14px">
    <h3>Escudos</h3>
    <button class="fu-btn" type="button" data-action="createItem" data-type="shield">
      <i class="fas fa-plus"></i>
    </button>
  </div>

  <div class="fu-item-list">
  {{#each shields}}
    <div class="fu-item-row" data-item-id="{{this.id}}">
      <a class="equipped-toggle {{#if this.system.equipped}}equipped{{/if}}"
         data-action="toggleEquip">
        <i class="fas {{#if this.system.equipped}}fa-shield-alt{{else}}fa-circle{{/if}}"></i>
      </a>
      <img class="item-img" src="{{this.img}}" alt="{{this.name}}">
      <span class="item-name" data-action="editItem">{{this.name}}</span>
      <span class="fu-muted" style="font-size:11px">
        DEF +{{this.system.defBonus}} · DEF.M +{{this.system.mdefBonus}}
      </span>
      <div class="item-controls">
        <a data-action="editItem"   title="Editar"><i class="fas fa-edit"></i></a>
        <a data-action="deleteItem" title="Excluir" class="fu-btn-danger"><i class="fas fa-trash"></i></a>
      </div>
    </div>
  {{else}}
    <p class="fu-muted fu-empty-notice">Nenhum escudo.</p>
  {{/each}}
  </div>

  {{!-- Consumables + Misc --}}
  <div class="fu-section-header" style="margin-top:14px">
    <h3>Inventário</h3>
    <button class="fu-btn" type="button" data-action="createItem" data-type="consumable">
      <i class="fas fa-flask"></i>
    </button>
    <button class="fu-btn" type="button" data-action="createItem" data-type="misc">
      <i class="fas fa-box"></i>
    </button>
  </div>

  <div class="fu-item-list">
  {{#each consumables}}
    <div class="fu-item-row" data-item-id="{{this.id}}">
      <img class="item-img" src="{{this.img}}" alt="{{this.name}}">
      <span class="item-name" data-action="editItem">{{this.name}}</span>
      <span class="fu-muted">×{{this.system.quantity}}</span>
      <div class="item-controls">
        <a data-action="useItem"    title="Usar"><i class="fas fa-hand-paper"></i></a>
        <a data-action="deleteItem" title="Excluir" class="fu-btn-danger"><i class="fas fa-trash"></i></a>
      </div>
    </div>
  {{/each}}
  {{#each misc}}
    <div class="fu-item-row" data-item-id="{{this.id}}">
      <img class="item-img" src="{{this.img}}" alt="{{this.name}}">
      <span class="item-name" data-action="editItem">{{this.name}}</span>
      <div class="item-controls">
        <a data-action="deleteItem" title="Excluir" class="fu-btn-danger"><i class="fas fa-trash"></i></a>
      </div>
    </div>
  {{/each}}
  {{#unless consumables}}{{#unless misc}}
    <p class="fu-muted fu-empty-notice">Inventário vazio.</p>
  {{/unless}}{{/unless}}
  </div>

</div>
