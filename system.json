    "styles/themes/livro.css",
    "styles/themes/jrpg.css",
    "styles/components/bars.css",
    "styles/components/dice.css",
    "styles/components/conditions.css",
    "styles/components/chat.css",
    "styles/components/wizard.css"
  ],
  "languages": [
